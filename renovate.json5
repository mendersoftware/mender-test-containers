{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":gitSignOff",
    ":rebaseStalePrs"
  ],
  "reviewersFromCodeOwners": true,

  "packageRules": [],

  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/gui-e2e-testing\/Dockerfile/", "/base-mender-cpp\/Dockerfile/"],
      "matchStrings": [
        "MENDER_ARTIFACT_VERSION=\\s*[\"']?(?<currentValue>[\\d\\.]+)[\"']?"
      ],
      "depNameTemplate": "mendersoftware/mender-artifact",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.*)$",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/base-mender-go-test\/Dockerfile/"],
      "matchStrings": [
        "go install gotest\\.tools/gotestsum@(?<currentValue>v[\\d\\.]+)"
      ],
      "depNameTemplate": "gotestyourself/gotestsum",
      "datasourceTemplate": "github-tags"
    },
  ],

  "prHourlyLimit": 0
}
